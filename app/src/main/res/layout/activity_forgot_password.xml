<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="54dp"
            android:paddingTop="72dp"
            android:paddingBottom="40dp">

            <ImageView
                android:layout_width="205dp"
                android:layout_height="133dp"
                android:layout_marginBottom="24dp"
                android:scaleType="fitCenter"
                app:srcCompat="@drawable/logo_1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:layout_marginBottom="24dp"
                android:text="Восстановление"
                android:textColor="@color/text_primary"
                android:textSize="32sp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxCornerRadiusBottomEnd="15dp"
                app:boxCornerRadiusBottomStart="15dp"
                app:boxCornerRadiusTopEnd="15dp"
                app:boxCornerRadiusTopStart="15dp"
                app:boxStrokeColor="@color/border"
                app:boxBackgroundColor="@color/background_input"
                android:textColorHint="@color/text_hint">

                <EditText
                    android:id="@+id/et_login"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Логин"
                    android:inputType="text"
                    android:textSize="16sp"
                    android:paddingVertical="12dp"
                    android:paddingHorizontal="17dp"
                    android:textColor="@color/text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_get_question"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Получить секретный вопрос"
                android:textSize="16sp"
                android:textColor="@color/button_text"
                android:background="@drawable/rounded_button"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tv_security_question"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:paddingVertical="12dp"
                android:paddingHorizontal="17dp"
                android:background="@drawable/rounded_edittext"
                android:layout_marginBottom="16dp"
                android:minHeight="56dp"
                android:gravity="center_vertical" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxCornerRadiusBottomEnd="15dp"
                app:boxCornerRadiusBottomStart="15dp"
                app:boxCornerRadiusTopEnd="15dp"
                app:boxCornerRadiusTopStart="15dp"
                app:boxStrokeColor="@color/border"
                app:boxBackgroundColor="@color/background_input"
                android:textColorHint="@color/text_hint">

                <EditText
                    android:id="@+id/et_security_answer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ответ на доп. вопрос"
                    android:inputType="text"
                    android:textSize="16sp"
                    android:paddingVertical="12dp"
                    android:paddingHorizontal="17dp"
                    android:textColor="@color/text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxCornerRadiusBottomEnd="15dp"
                app:boxCornerRadiusBottomStart="15dp"
                app:boxCornerRadiusTopEnd="15dp"
                app:boxCornerRadiusTopStart="15dp"
                app:boxStrokeColor="@color/border"
                app:boxBackgroundColor="@color/background_input"
                app:passwordToggleEnabled="true"
                android:textColorHint="@color/text_hint">

                <EditText
                    android:id="@+id/et_new_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Пароль"
                    android:inputType="textPassword"
                    android:textSize="16sp"
                    android:paddingVertical="12dp"
                    android:paddingHorizontal="17dp"
                    android:textColor="@color/text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxCornerRadiusBottomEnd="15dp"
                app:boxCornerRadiusBottomStart="15dp"
                app:boxCornerRadiusTopEnd="15dp"
                app:boxCornerRadiusTopStart="15dp"
                app:boxStrokeColor="@color/border"
                app:boxBackgroundColor="@color/background_input"
                app:passwordToggleEnabled="true"
                android:textColorHint="@color/text_hint">

                <EditText
                    android:id="@+id/et_confirm_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Подтверждение пароля"
                    android:inputType="textPassword"
                    android:textSize="16sp"
                    android:paddingVertical="12dp"
                    android:paddingHorizontal="17dp"
                    android:textColor="@color/text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_reset_password"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Восстановить"
                android:textSize="16sp"
                android:textColor="@color/button_text"
                android:background="@drawable/rounded_button" />

        </LinearLayout>
    </ScrollView>

    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_margin="9dp"
        android:background="@drawable/circle_green_background"
        android:scaleType="center"
        android:visibility="visible"
        android:stateListAnimator="@animator/scale_button"
        />

</RelativeLayout>