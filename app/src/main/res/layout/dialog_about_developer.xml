<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@drawable/dialog_background">

        <!-- Иконка приложения -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:src="@mipmap/ic_launcher"
            android:layout_marginBottom="16dp" />

        <!-- Название приложения -->
        <TextView
            android:id="@+id/tv_app_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="HomeBudget"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#4CAF50"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <!-- Версия -->
        <TextView
            android:id="@+id/tv_app_version"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Версия 1.0"
            android:textSize="12sp"
            android:textColor="#999999"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Разделитель -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="16dp" />

        <!-- Информация о разработчике -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👨‍💻 О РАЗРАБОТЧИКЕ"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#4CAF50"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tv_developer_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Азизов Бахтияр"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Студент-разработчик"
                android:textSize="12sp"
                android:textColor="#999999"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

        </LinearLayout>

        <!-- Разделитель -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="16dp" />

        <!-- Контакты -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📞 КОНТАКТЫ"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#4CAF50"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <!-- Email -->
            <LinearLayout
                android:id="@+id/tv_developer_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="✉️"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="studentazizov@gmail.com"
                    android:textSize="14sp"
                    android:textColor="#2196F3" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📧"
                    android:textSize="14sp"
                    android:textColor="#999999" />

            </LinearLayout>

            <!-- Telegram -->
            <LinearLayout
                android:id="@+id/tv_developer_telegram"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="💬"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@titan01111"
                    android:textSize="14sp"
                    android:textColor="#2196F3" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📱"
                    android:textSize="14sp"
                    android:textColor="#999999" />

            </LinearLayout>

            <!-- GitHub -->
            <LinearLayout
                android:id="@+id/tv_developer_github"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="🐙"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bob-05"
                    android:textSize="14sp"
                    android:textColor="#2196F3" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔗"
                    android:textSize="14sp"
                    android:textColor="#999999" />

            </LinearLayout>

        </LinearLayout>

        <!-- Разделитель -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="16dp" />

        <!-- Описание приложения -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📱 О ПРИЛОЖЕНИИ"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#4CAF50"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="HomeBudget — умный помощник для учёта личных финансов. \n\n✅ Учёт доходов и расходов\n✅ Категории транзакций\n✅ Детальная аналитика и отчёты\n✅ ИИ-ассистент для советов\n✅ Экспорт в PDF\n✅ Push-уведомления"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>

        <!-- Разделитель -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="16dp" />

        <!-- Копирайт -->
        <TextView
            android:id="@+id/tv_copyright"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="© 2026 HomeBudget"
            android:textSize="10sp"
            android:textColor="#999999"
            android:gravity="center"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>

</ScrollView>