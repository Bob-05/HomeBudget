<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/dialog_background">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Финансовый отчет"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#4CAF50"
        android:layout_marginBottom="16dp"
        android:gravity="center" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Тип отчета:"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/rg_report_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <RadioButton
            android:id="@+id/rb_income"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💰 Отчет по доходам"
            android:padding="8dp" />

        <RadioButton
            android:id="@+id/rb_expense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💸 Отчет по расходам"
            android:padding="8dp" />

        <RadioButton
            android:id="@+id/rb_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 Сводный отчет (доходы/расходы)"
            android:padding="8dp"
            android:checked="true" />

        <RadioButton
            android:id="@+id/rb_categories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📂 Отчет по категориям"
            android:padding="8dp" />

        <RadioButton
            android:id="@+id/rb_period"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📅 Список транзакций за период"
            android:padding="8dp" />

    </RadioGroup>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Период отчета"
        android:textSize="14sp"
        android:textColor="@color/text_hint"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tv_start_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:padding="12dp"
            android:background="@drawable/search_background"
            android:text="Начальная дата"
            android:textColor="#000000"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" - "
            android:padding="12dp" />

        <TextView
            android:id="@+id/tv_end_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:padding="12dp"
            android:background="@drawable/search_background"
            android:text="Конечная дата"
            android:gravity="center"
            android:textColor="#000000" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Отмена"
            android:backgroundTint="#9E9E9E"
            android:textColor="@android:color/white"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_generate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Сформировать"
            android:backgroundTint="@color/rounded_button"
            android:textColor="@android:color/black" />

    </LinearLayout>

</LinearLayout>